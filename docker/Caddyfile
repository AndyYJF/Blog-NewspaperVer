# Drop-in reverse-proxy config — automatic HTTPS via Let's Encrypt.
# Place at /etc/caddy/Caddyfile (or alongside docker-compose) and replace
# the host below with your real domain.

your-domain.example {
    encode zstd gzip

    # Long cache for hashed Next.js assets
    @nextStatic path /_next/static/*
    header @nextStatic Cache-Control "public, max-age=31536000, immutable"

    # Editor uploads — short cache, can be edited from admin
    @uploads path /uploads/*
    header @uploads Cache-Control "public, max-age=3600"

    reverse_proxy 127.0.0.1:3000 {
        # Restore client info to Next.js (used by Auth.js and image optimizer)
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
        # Bigger header buffer — preload Link headers can be large
        flush_interval -1
    }
}
